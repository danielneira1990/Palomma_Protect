# Copia este archivo a .env.local y completa con tus llaves de Supabase.
# (Settings → API en tu proyecto de Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo en el servidor (backoffice). NO la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Google Drive / Docs (generación del Contrato Marco) ---
# base64 del JSON del service account. Solo servidor; NO exponer al cliente.
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=tu-service-account-en-base64
GOOGLE_DRIVE_TEMPLATE_CONTRATO_MARCO_ID=id-del-google-doc-plantilla
GOOGLE_DRIVE_INMOBILIARIAS_FOLDER_ID=id-de-la-carpeta-de-salida
# Reglamentos (condicionados) que se adjuntan al correo de bienvenida:
GOOGLE_DRIVE_REGLAMENTO_GENERAL_ID=id-del-reglamento-general
GOOGLE_DRIVE_REGLAMENTO_INTEGRAL_ID=id-del-reglamento-integral
GOOGLE_DRIVE_REGLAMENTO_PENAL_ID=id-del-reglamento-penal
# Plantilla del paz y salvo de inducción (Google Doc):
GOOGLE_DRIVE_TEMPLATE_PAZ_SALVO_ID=id-del-paz-y-salvo

# --- Motor de scoring (servicio Python) ---
SCORING_SERVICE_URL=http://127.0.0.1:8000

# --- Correo (SMTP) — envío de bienvenida a inmobiliarias ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-correo@palomma.com
SMTP_PASS=tu-contrasena-de-aplicacion
MAIL_FROM=Palomma Protect <tu-correo@palomma.com>
PORTAL_URL=http://localhost:3000/inmobiliaria
